{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "grade4math/math-problem",
  "version": "1.0.0",
  "title": "Math Problem",
  "category": "widgets",
  "icon": "calculator",
  "description": "Add a styled Grade 4 math problem with a show/hide answer.",
  "keywords": [
    "math",
    "problem",
    "grade4",
    "question"
  ],
  "attributes": {
    "question": {
      "type": "string",
      "default": ""
    },
    "answer": {
      "type": "string",
      "default": ""
    },
    "hint": {
      "type": "string",
      "default": ""
    },
    "level": {
      "type": "string",
      "default": "easy"
    },
    "topic": {
      "type": "string",
      "default": "multiplication"
    },
    "studentAnswer": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}